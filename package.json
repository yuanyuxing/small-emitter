{
  "name": "small-emitter",
  "version": "0.0.6-beta.1",
  "description": "a simple release and subscription lib",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch src",
    "test": "jest",
    "release": "bumpp package.json --commit --push --tag",
    "publish": "npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuanyuxing/small-emitter.git"
  },
  "keywords": [
    "emitter",
    "small",
    "small-emiter",
    "emit"
  ],
  "author": "yuanyuxing",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yuanyuxing/small-emitter/issues"
  },
  "homepage": "https://github.com/yuanyuxing/small-emitter#readme",
  "devDependencies": {
    "@antfu/eslint-config": "^0.10.0",
    "@types/jest": "^27.0.2",
    "@typescript-eslint/eslint-plugin": "^5.3.1",
    "@typescript-eslint/parser": "^5.3.1",
    "bumpp": "^7.1.1",
    "eslint": "7.28.0",
    "jest": "^27.3.1",
    "ts-jest": "^27.0.7",
    "ts-node": "^10.4.0",
    "tsup": "^5.6.0",
    "typescript": "^4.4.4"
  },
  "dependencies": {
    "small-emitter": "^0.0.4"
  }
}
